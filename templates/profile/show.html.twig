{% extends 'base.html.twig' %}

{% block title %}{{ user.username }}{% endblock %}

{% block body %}
<div class="row">
    <div class="col-lg-4">
        <div class="card-gf text-center mb-4">
            <div class="mb-3">{{ user_avatar(user.avatar, user.username, 'lg') }}</div>

            <h3>{{ user.username }}
                {% if user.premium %}
                    <span class="premium-badge">PRO</span>
                {% endif %}
            </h3>

            {% if user.bio %}
                <p style="color:var(--gf-muted)">{{ user.bio }}</p>
            {% endif %}

            <div class="d-flex justify-content-center gap-2 flex-wrap mb-3">
                {% if user.city %}
                    <span class="badge-gf"><i class="fas fa-map-marker-alt me-1"></i>{{ user.city }}</span>
                {% endif %}
                {% if user.language %}
                    <span class="badge-gf"><i class="fas fa-globe me-1"></i>{{ user.language }}</span>
                {% endif %}
                {% if user.age %}
                    <span class="badge-gf"><i class="fas fa-birthday-cake me-1"></i>{{ user.age }}</span>
                {% endif %}
            </div>

            {# Stats #}
            <div class="row g-2 mb-3">
                <div class="col-4">
                    <div class="stat-card">
                        <div class="stat-value">{{ user.rating|round(0) }}%</div>
                        <div class="stat-label">Рейтинг</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="stat-card">
                        <div class="stat-value">{{ user.totalReviews }}</div>
                        <div class="stat-label">Відгуки</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="stat-card">
                        <div class="stat-value">{{ achievements|length }}</div>
                        <div class="stat-label">Ачівки</div>
                    </div>
                </div>
            </div>

            {% if isOwn %}
                <a href="{{ path('app_profile_edit') }}" class="btn btn-gf w-100">
                    <i class="fas fa-edit me-1"></i> Редагувати профіль
                </a>
            {% else %}
                <div class="d-flex gap-2">
                    {% if friendshipStatus is defined and friendshipStatus == 'accepted' %}
                        <span class="btn btn-gf-success flex-fill text-center" style="cursor:default;">
                            <i class="fas fa-user-check me-1"></i> Друзі
                        </span>
                    {% elseif friendshipStatus is defined and friendshipStatus == 'pending' %}
                        <span class="btn btn-gf-outline flex-fill text-center" style="cursor:default;">
                            <i class="fas fa-clock me-1"></i> Запит надіслано
                        </span>
                    {% else %}
                        <form action="{{ path('app_friend_add', {id: user.id}) }}" method="post" class="flex-fill">
                            <button class="btn btn-gf w-100"><i class="fas fa-user-plus me-1"></i> Додати</button>
                        </form>
                    {% endif %}
                    <a href="{{ path('app_private_chat', {id: user.id}) }}" class="btn btn-gf-outline flex-fill">
                        <i class="fas fa-envelope me-1"></i> Написати
                    </a>
                </div>
                <div class="mt-2">
                    <button class="btn btn-sm w-100" style="color:var(--gf-muted);background:transparent;border:1px solid var(--gf-border);border-radius:8px;" type="button" data-bs-toggle="collapse" data-bs-target="#reportUserForm">
                        <i class="fas fa-flag me-1"></i> Поскаржитись
                    </button>
                    <div class="collapse mt-2" id="reportUserForm">
                        <form action="{{ path('app_report_user', {id: user.id}) }}" method="post">
                            <textarea name="reason" class="form-control form-control-sm mb-2" rows="2" placeholder="Причина скарги..." required></textarea>
                            <button type="submit" class="btn btn-gf-danger btn-sm w-100"><i class="fas fa-paper-plane me-1"></i>Надіслати скаргу</button>
                        </form>
                    </div>
                </div>
            {% endif %}

            <div class="mt-3 text-start">
                <small style="color:var(--gf-muted)">
                    <i class="fas fa-clock me-1"></i> На платформі з {{ user.createdAt|date('d.m.Y') }}
                </small>
                {% if user.steamId %}
                <br><small style="color:var(--gf-muted)">
                    <i class="fab fa-steam me-1"></i> Steam підключено
                </small>
                {% endif %}
                {% if user.discordId %}
                <br><small style="color:var(--gf-muted)">
                    <i class="fab fa-discord me-1"></i> Discord підключено
                </small>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        {# Achievements grouped by game #}
        <div class="card-gf mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0"><i class="fas fa-trophy me-2" style="color:var(--gf-warning)"></i>Досягнення <span class="badge-gf ms-2">{{ achievements|length }}</span></h4>
            </div>
            {% if achievements is empty %}
                <p style="color:var(--gf-muted)">Немає досягнень. {% if isOwn and user.steamId %}Відкрийте будь-яку гру та натисніть "Синхронізувати".{% elseif isOwn %}Додайте Steam ID у налаштуваннях профілю.{% endif %}</p>
            {% else %}
                {# Group achievements by game #}
                {% set gameGroups = {} %}
                {% for ach in achievements %}
                    {% set gameName = ach.game.name %}
                    {% if gameName not in gameGroups|keys %}
                        {% set gameGroups = gameGroups|merge({(gameName): []}) %}
                    {% endif %}
                    {% set gameGroups = gameGroups|merge({(gameName): gameGroups[gameName]|merge([ach])}) %}
                {% endfor %}

                {# Game tabs #}
                <div class="d-flex gap-2 flex-wrap mb-3">
                    {% set first = true %}
                    {% for gameName, achs in gameGroups %}
                        <button class="btn {{ first ? 'btn-gf' : 'btn-gf-outline' }} btn-sm game-tab-btn" data-game="{{ gameName|replace({' ': '_', ':': ''}) }}" onclick="showGameAch(this, '{{ gameName|replace({' ': '_', ':': ''}) }}')">
                            {{ gameName }} <span class="badge rounded-pill" style="background:rgba(255,255,255,0.2);font-size:0.7rem;">{{ achs|length }}</span>
                        </button>
                        {% set first = false %}
                    {% endfor %}
                </div>

                {# Achievement lists per game #}
                {% set first = true %}
                {% for gameName, achs in gameGroups %}
                <div class="game-ach-list" id="ach_{{ gameName|replace({' ': '_', ':': ''}) }}" style="{{ not first ? 'display:none;' : '' }}">
                    <div style="max-height:300px;overflow-y:auto;padding-right:0.5rem;">
                        {% for ach in achs %}
                        <div class="d-flex align-items-center gap-2 p-2 mb-1" style="background:var(--gf-dark);border-radius:8px;">
                            <div style="width:32px;height:32px;border-radius:6px;background:var(--gf-warning);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                {% if ach.iconUrl %}
                                    <img src="{{ ach.iconUrl }}" style="width:32px;height:32px;border-radius:6px;" alt="{{ ach.name }}">
                                {% else %}
                                    <i class="fas fa-star text-dark" style="font-size:0.8rem;"></i>
                                {% endif %}
                            </div>
                            <div class="flex-fill" style="min-width:0;">
                                <div style="font-size:0.8rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ ach.name }}</div>
                                {% if ach.description %}
                                    <div style="font-size:0.7rem;color:var(--gf-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ ach.description }}</div>
                                {% endif %}
                            </div>
                            {% if ach.unlockedAt %}
                                <small style="color:var(--gf-muted);font-size:0.7rem;flex-shrink:0;">{{ ach.unlockedAt|date('d.m.Y') }}</small>
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>
                </div>
                {% set first = false %}
                {% endfor %}
            {% endif %}
        </div>

        {# Reviews #}
        <div class="card-gf mb-4">
            <h4 class="mb-3"><i class="fas fa-star me-2" style="color:var(--gf-secondary)"></i>Відгуки</h4>

            {% if not isOwn %}
            <form action="{{ path('app_review_create', {id: user.id}) }}" method="post" class="mb-4 p-3" style="background:var(--gf-dark);border-radius:12px;">
                <div class="d-flex gap-2 mb-2">
                    <button type="submit" name="rating" value="positive" class="btn btn-gf-success flex-fill">
                        <i class="fas fa-thumbs-up me-1"></i> Позитивний
                    </button>
                    <button type="submit" name="rating" value="negative" class="btn btn-gf-danger flex-fill">
                        <i class="fas fa-thumbs-down me-1"></i> Негативний
                    </button>
                </div>
                <textarea name="comment" class="form-control" rows="2" placeholder="Коментар (необов'язково)"></textarea>
            </form>
            {% endif %}

            {% for review in reviews %}
            <div class="d-flex gap-3 mb-3 p-3" style="background:var(--gf-dark);border-radius:12px;">
                <div>
                    {% if review.isPositive %}
                        <i class="fas fa-thumbs-up fa-lg rating-positive"></i>
                    {% else %}
                        <i class="fas fa-thumbs-down fa-lg rating-negative"></i>
                    {% endif %}
                </div>
                <div class="flex-fill">
                    <strong>
                        <a href="{{ path('app_profile_public', {id: review.author.id}) }}" class="text-decoration-none" style="color:var(--gf-text)">
                            {{ review.author.username }}
                        </a>
                    </strong>
                    {% if review.comment %}
                        <p class="mb-0 mt-1" style="color:var(--gf-muted)">{{ review.comment }}</p>
                    {% endif %}
                    <small style="color:var(--gf-muted)">{{ review.createdAt|date('d.m.Y H:i') }}</small>
                </div>
            </div>
            {% else %}
                <p style="color:var(--gf-muted)">Ще немає відгуків</p>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
function showGameAch(btn, gameId) {
    document.querySelectorAll('.game-ach-list').forEach(el => el.style.display = 'none');
    document.querySelectorAll('.game-tab-btn').forEach(el => {
        el.classList.remove('btn-gf');
        el.classList.add('btn-gf-outline');
    });
    const target = document.getElementById('ach_' + gameId);
    if (target) target.style.display = 'block';
    btn.classList.remove('btn-gf-outline');
    btn.classList.add('btn-gf');
}
</script>
{% endblock %}
