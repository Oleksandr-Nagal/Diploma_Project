{% extends 'base.html.twig' %}

{% block title %}Рейтинг{% endblock %}

{% block body %}
    <div class="page-header">
        <h1><i class="fas fa-ranking-star me-2" style="color:var(--gf-warning)"></i>Глобальний рейтинг</h1>
        <p style="color:var(--gf-muted)">Найкращі гравці на платформі за відгуками та досягненнями</p>
    </div>

    <div class="card-gf">
        <div class="table-responsive">
            <table class="table table-borderless mb-0">
                <thead>
                <tr>
                    <th style="width:60px">#</th>
                    <th>Гравець</th>
                    <th class="text-center">Рейтинг</th>
                    <th class="text-center">Відгуки</th>
                    <th class="text-center">Досягнення</th>
                    <th class="text-center">Профіль</th>
                </tr>
                </thead>
                <tbody>
                {% for user in leaders %}
                    <tr style="{{ loop.index <= 3 ? 'background:rgba(108,92,231,0.05);' : '' }}">
                        <td>
                            {% if loop.index == 1 %}
                                <span style="font-size:1.5rem;">🥇</span>
                            {% elseif loop.index == 2 %}
                                <span style="font-size:1.5rem;">🥈</span>
                            {% elseif loop.index == 3 %}
                                <span style="font-size:1.5rem;">🥉</span>
                            {% else %}
                                <span style="color:var(--gf-muted);font-size:1.1rem;font-weight:600;">{{ loop.index }}</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                {{ user_avatar(user.avatar, user.username, 'sm') }}
                                <strong>{{ user.username }}</strong>
                                {% if user.premium %}<span class="premium-badge ms-1">PRO</span>{% endif %}
                            </div>
                        </td>
                        <td class="text-center">
                        <span class="{{ user.rating >= 70 ? 'rating-positive' : (user.rating >= 40 ? '' : 'rating-negative') }}" style="font-weight:700;font-size:1.1rem;">
                            {{ user.rating|round(0) }}%
                        </span>
                        </td>
                        <td class="text-center">{{ user.totalReviews }}</td>
                        <td class="text-center">{{ user.achievements|length }}</td>
                        <td class="text-center">
                            <a href="{{ path('app_profile_public', {id: user.id}) }}" class="btn btn-gf btn-sm"><i class="fas fa-eye"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center py-4" style="color:var(--gf-muted)">Поки немає гравців у рейтингу</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
