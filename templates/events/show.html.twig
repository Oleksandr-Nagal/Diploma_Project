{% extends 'base.html.twig' %}

{% block title %}{{ event.title }}{% endblock %}

{% block body %}
<div class="row">
    <div class="col-lg-8">
        <div class="card-gf mb-4">
            <div class="d-flex justify-content-between mb-3">
                <span class="badge-gf"><i class="fas fa-gamepad me-1"></i>{{ event.game.name }}</span>
                <span class="badge-gf {{ event.status == 'planned' ? 'badge-gf-success' : 'badge-gf-warning' }}">{{ event.status }}</span>
            </div>
            <h2>{{ event.title }}</h2>
            {% if event.description %}
                <p style="color:var(--gf-muted)">{{ event.description }}</p>
            {% endif %}

            <div class="row g-3 my-3">
                <div class="col-md-4">
                    <div class="stat-card" style="background:var(--gf-dark);border-radius:12px;">
                        <div style="color:var(--gf-warning);font-size:1.5rem;"><i class="fas fa-clock"></i></div>
                        <div class="stat-label">Початок</div>
                        <strong>{{ event.startAt|date('d.m.Y H:i') }}</strong>
                    </div>
                </div>
                {% if event.endAt %}
                <div class="col-md-4">
                    <div class="stat-card" style="background:var(--gf-dark);border-radius:12px;">
                        <div style="color:var(--gf-danger);font-size:1.5rem;"><i class="fas fa-flag-checkered"></i></div>
                        <div class="stat-label">Кінець</div>
                        <strong>{{ event.endAt|date('d.m.Y H:i') }}</strong>
                    </div>
                </div>
                {% endif %}
                <div class="col-md-4">
                    <div class="stat-card" style="background:var(--gf-dark);border-radius:12px;">
                        <div style="color:var(--gf-success);font-size:1.5rem;"><i class="fas fa-users"></i></div>
                        <div class="stat-label">Учасники</div>
                        <strong>{{ event.participants|length }}/{{ event.maxParticipants }}</strong>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                {% if not isParticipant and not isOrganizer %}
                    <form action="{{ path('app_event_join', {id: event.id}) }}" method="post">
                        <button class="btn btn-gf"><i class="fas fa-hand-point-up me-1"></i> Приєднатися</button>
                    </form>
                {% endif %}

                {% if isParticipant or isOrganizer %}
                    <a href="{{ path('app_event_chat', {id: event.id}) }}" class="btn btn-gf-outline">
                        <i class="fas fa-comments me-1"></i> Чат події
                    </a>
                {% endif %}

                {% if isParticipant and not isOrganizer %}
                    <form action="{{ path('app_event_leave', {id: event.id}) }}" method="post">
                        <button class="btn btn-gf-danger"><i class="fas fa-sign-out me-1"></i> Покинути подію</button>
                    </form>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card-gf mb-4">
            <h5><i class="fas fa-user me-2" style="color:var(--gf-primary)"></i>Організатор</h5>
            <div class="d-flex align-items-center gap-3 mt-3">
                {{ user_avatar(event.organizer.avatar, event.organizer.username, 'md') }}
                <div>
                    <a href="{{ path('app_profile_public', {id: event.organizer.id}) }}" class="text-decoration-none" style="color:var(--gf-text)">
                        <strong>{{ event.organizer.username }}</strong>
                    </a>
                </div>
            </div>
        </div>

        <div class="card-gf">
            <h5><i class="fas fa-users me-2" style="color:var(--gf-success)"></i>Учасники</h5>
            {% for p in event.participants %}
            <div class="d-flex align-items-center gap-2 mt-2 p-2" style="background:var(--gf-dark);border-radius:10px;">
                {{ user_avatar(p.avatar, p.username, 'sm') }}
                <a href="{{ path('app_profile_public', {id: p.id}) }}" class="text-decoration-none" style="color:var(--gf-text)">{{ p.username }}</a>
            </div>
            {% else %}
                <p class="mt-2" style="color:var(--gf-muted)">Поки немає учасників</p>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
