{% extends 'base.html.twig' %}

{% block title %}Календар подій{% endblock %}

{% block body %}
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1><i class="fas fa-calendar me-2" style="color:var(--gf-warning)"></i>Календар подій</h1>
        <p style="color:var(--gf-muted)">Плануй ігрові сесії наперед</p>
    </div>
    <a href="{{ path('app_event_create') }}" class="btn btn-gf">
        <i class="fas fa-plus me-1"></i> Створити подію
    </a>
</div>

{% if events is empty %}
    <div class="card-gf text-center py-5">
        <i class="fas fa-calendar-xmark fa-4x mb-3" style="color:var(--gf-muted)"></i>
        <h4 style="color:var(--gf-muted)">Немає запланованих подій</h4>
        <a href="{{ path('app_event_create') }}" class="btn btn-gf mt-2">Створити першу подію</a>
    </div>
{% else %}
    <div class="row g-3">
        {% for event in events %}
        <div class="col-md-6 col-lg-4">
            <div class="card-gf h-100">
                <div class="d-flex justify-content-between mb-2">
                    <span class="badge-gf"><i class="fas fa-gamepad me-1"></i>{{ event.game.name }}</span>
                    <span class="badge-gf {{ event.status == 'planned' ? 'badge-gf-success' : 'badge-gf-warning' }}">{{ event.status }}</span>
                </div>
                <h5>
                    <a href="{{ path('app_event_show', {id: event.id}) }}" class="text-decoration-none" style="color:var(--gf-text)">{{ event.title }}</a>
                </h5>
                {% if event.description %}
                    <p class="small" style="color:var(--gf-muted)">{{ event.description|slice(0, 100) }}</p>
                {% endif %}
                <div class="d-flex gap-2 flex-wrap mb-3">
                    <span class="badge-gf badge-gf-warning"><i class="fas fa-clock me-1"></i>{{ event.startAt|date('d.m.Y H:i') }}</span>
                    <span class="badge-gf badge-gf-success"><i class="fas fa-users me-1"></i>{{ event.participants|length }}/{{ event.maxParticipants }}</span>
                </div>
                <small style="color:var(--gf-muted)"><i class="fas fa-user me-1"></i>{{ event.organizer.username }}</small>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
