<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="GameFinder — вебплатформа для пошуку та підбору партнерів у багатокористувацьких онлайн-іграх.">
    <title>{% block title %}GameFinder{% endblock %} | GameFinder</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <style>
        :root, [data-theme="dark"] {
            --gf-primary: #6c5ce7;
            --gf-secondary: #00cec9;
            --gf-dark: #0a0a1a;
            --gf-darker: #060612;
            --gf-card: #12122a;
            --gf-border: #1e1e3a;
            --gf-text: #e0e0ff;
            --gf-muted: #9999bb;
            --gf-success: #00b894;
            --gf-danger: #ff6b6b;
            --gf-warning: #fdcb6e;
            --gf-input-bg: #0d0d25;
            --gf-input-border: #2a2a4a;
            --gf-navbar-bg: linear-gradient(135deg, #0a0a1a 0%, #0d0d2b 100%);
            --gf-dropdown-bg: #12122a;
        }

        [data-theme="light"] {
            --gf-primary: #6c5ce7;
            --gf-secondary: #0984e3;
            --gf-dark: #f0f0f5;
            --gf-darker: #e8e8f0;
            --gf-card: #ffffff;
            --gf-border: #d0d0e0;
            --gf-text: #1a1a2e;
            --gf-muted: #666688;
            --gf-success: #00b894;
            --gf-danger: #d63031;
            --gf-warning: #e17055;
            --gf-input-bg: #ffffff;
            --gf-input-border: #c0c0d8;
            --gf-navbar-bg: linear-gradient(135deg, #ffffff 0%, #f0f0ff 100%);
            --gf-dropdown-bg: #ffffff;
        }

        body {
            background: var(--gf-darker);
            color: var(--gf-text);
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            min-height: 100vh;
        }

        .navbar-gf {
            background: var(--gf-navbar-bg);
            border-bottom: 1px solid var(--gf-border);
            padding: 0.75rem 0;
        }

        .navbar-gf .navbar-brand {
            color: var(--gf-secondary);
            font-weight: 800;
            font-size: 1.5rem;
            letter-spacing: 1px;
        }

        .navbar-gf .nav-link {
            color: var(--gf-muted);
            font-weight: 500;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            transition: all 0.2s;
        }

        .navbar-gf .nav-link:hover { color: #fff; background: rgba(108, 92, 231, 0.15); }

        .btn-gf {
            background: linear-gradient(135deg, var(--gf-primary), #a855f7);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 0.5rem 1.5rem;
            font-weight: 600;
        }

        .card-gf {
            background: var(--gf-card);
            border: 1px solid var(--gf-border);
            border-radius: 16px;
            padding: 1.5rem;
        }

        .form-control {
            background: var(--gf-input-bg);
            border: 2px solid var(--gf-input-border);
            color: var(--gf-text);
            border-radius: 10px;
            padding: 0.75rem 1rem;
        }

        footer {
            background: var(--gf-dark);
            border-top: 1px solid var(--gf-border);
            padding: 2rem 0;
            margin-top: 3rem;
            color: var(--gf-muted);
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-gf sticky-top">
    <div class="container">
        <a class="navbar-brand" href="/">
            <i class="fas fa-gamepad me-2"></i>GameFinder
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <i class="fas fa-bars text-white"></i>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            {% if app.user %}
                <ul class="navbar-nav me-auto" id="gf-nav-links">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_games') }}"><i class="fas fa-trophy me-1"></i> Ігри</a>
                    </li>
                </ul>

                <ul class="navbar-nav" id="gf-nav-actions">
                    <li class="nav-item dropdown" id="gf-nav-profile">
                        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" data-bs-toggle="dropdown">
                            <span class="ms-2">{{ app.user.email }}</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" style="background:var(--gf-dropdown-bg);border-color:var(--gf-border);">
                            <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="fas fa-sign-out me-2"></i>Вийти</a></li>
                        </ul>
                    </li>
                </ul>
            {% else %}
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_login') }}">Вхід</a></li>
                    <li class="nav-item"><a class="btn btn-gf ms-2" href="{{ path('app_register') }}">Реєстрація</a></li>
                </ul>
            {% endif %}
        </div>
    </div>
</nav>

<main class="container py-4">
    {% block body %}{% endblock %}
</main>

<footer>
    <div class="container text-center">
        <p class="mb-1"><i class="fas fa-gamepad me-1"></i> GameFinder &copy; {{ "now"|date("Y") }}</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
