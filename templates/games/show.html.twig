{% extends 'base.html.twig' %}

{% block title %}{{ game.name }}{% endblock %}

{% block body %}
<div class="row">
    <div class="col-lg-4">
        <div class="card-gf text-center mb-4">
            {% if game.imageUrl %}
                <img src="{{ game.imageUrl }}" style="width:100%;height:200px;object-fit:cover;border-radius:12px;margin-bottom:1rem;" alt="">
            {% else %}
                <div style="width:100%;height:200px;border-radius:12px;margin-bottom:1rem;background:linear-gradient(135deg, var(--gf-primary), var(--gf-secondary));display:flex;align-items:center;justify-content:center;">
                    <i class="fas fa-gamepad fa-5x text-white"></i>
                </div>
            {% endif %}
            <h2>{{ game.name }}</h2>
            <div class="d-flex gap-2 justify-content-center mb-3">
                <span class="badge-gf">{{ game.genre }}</span>
                {% if game.maxPlayers %}<span class="badge-gf badge-gf-success"><i class="fas fa-users me-1"></i>До {{ game.maxPlayers }}</span>{% endif %}
            </div>
            {% if game.description %}
                <p style="color:var(--gf-muted)">{{ game.description }}</p>
            {% endif %}

            {% if game.steamAppId %}
                <form action="{{ path('app_game_sync_achievements', {id: game.id}) }}" method="post" class="mt-3">
                    <button class="btn btn-gf-outline w-100"><i class="fab fa-steam me-1"></i> Синхронізувати досягнення</button>
                </form>
            {% endif %}

            <a href="{{ path('app_lobby_create') }}" class="btn btn-gf w-100 mt-2">
                <i class="fas fa-plus me-1"></i> Створити лобі
            </a>
        </div>
    </div>

    <div class="col-lg-8">
        <h4 class="mb-3"><i class="fas fa-door-open me-2" style="color:var(--gf-primary)"></i>Відкриті лобі для {{ game.name }}</h4>

        {% for lobby in lobbies %}
        <div class="card-gf mb-3">
            <div class="d-flex justify-content-between">
                <div>
                    <h5><a href="{{ path('app_lobby_show', {id: lobby.id}) }}" class="text-decoration-none" style="color:var(--gf-text)">{{ lobby.title }}</a></h5>
                    <div class="d-flex gap-2 flex-wrap">
                        <span class="badge-gf badge-gf-success"><i class="fas fa-users me-1"></i>{{ lobby.currentMemberCount }}/{{ lobby.maxMembers }}</span>
                        {% if lobby.skillLevel != 'any' %}<span class="badge-gf badge-gf-warning">{{ lobby.skillLevel }}</span>{% endif %}
                        {% if lobby.voiceChat %}<span class="badge-gf" style="color:var(--gf-secondary)"><i class="fas fa-microphone me-1"></i>Voice</span>{% endif %}
                    </div>
                </div>
                <a href="{{ path('app_lobby_show', {id: lobby.id}) }}" class="btn btn-gf btn-sm align-self-center">Приєднатися</a>
            </div>
        </div>
        {% else %}
            <div class="card-gf text-center py-4">
                <p style="color:var(--gf-muted)">Немає відкритих лобі для цієї гри</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
