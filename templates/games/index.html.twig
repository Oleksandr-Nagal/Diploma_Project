{% extends 'base.html.twig' %}

{% block title %}Каталог ігор{% endblock %}

{% block body %}
<div class="page-header">
    <h1><i class="fas fa-trophy me-2" style="color:var(--gf-secondary)"></i>Каталог ігор</h1>
    <p style="color:var(--gf-muted)">Обери гру та знайди напарників</p>
</div>

<div class="row g-4">
    {% for game in games %}
    <div class="col-md-4 col-lg-3">
        <a href="{{ path('app_game_show', {id: game.id}) }}" class="card-gf d-block text-decoration-none text-center h-100">
            {% if game.imageUrl %}
                <img src="{{ game.imageUrl }}" style="width:100%;height:180px;object-fit:cover;border-radius:12px;margin-bottom:1rem;" alt="{{ game.name }}">
            {% else %}
                <div style="width:100%;height:180px;border-radius:12px;margin-bottom:1rem;background:linear-gradient(135deg, var(--gf-primary), var(--gf-secondary));display:flex;align-items:center;justify-content:center;">
                    <i class="fas fa-gamepad fa-4x text-white"></i>
                </div>
            {% endif %}
            <h5 style="color:var(--gf-text)">{{ game.name }}</h5>
            <span class="badge-gf">{{ game.genre }}</span>
            {% if game.maxPlayers %}
                <span class="badge-gf badge-gf-success ms-1"><i class="fas fa-users me-1"></i>{{ game.maxPlayers }}</span>
            {% endif %}
            {% if game.steamAppId %}
                <br><small class="mt-2 d-inline-block" style="color:var(--gf-muted)"><i class="fab fa-steam me-1"></i>Steam</small>
            {% endif %}
        </a>
    </div>
    {% else %}
        <div class="col-12">
            <div class="card-gf text-center py-5">
                <p style="color:var(--gf-muted)">Ігри ще не додані. Адміністратор може додати їх у панелі управління.</p>
            </div>
        </div>
    {% endfor %}
</div>
{% endblock %}
