{% extends 'base.html.twig' %}

{% block title %}Вхід{% endblock %}

{% block body %}
    <div class="row justify-content-center mt-5">
        <div class="col-md-5">
            <div class="card-gf text-center">
                <h2 class="mb-1"><i class="fas fa-gamepad me-2 glow-text"></i></h2>
                <h2 class="glow-text mb-4">Вхід до GameFinder</h2>

                {% if error %}
                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                <form method="post" action="{{ path('app_login') }}">
                    <div class="mb-3 text-start">
                        <label class="form-label"><i class="fas fa-envelope me-1"></i> Електронна пошта</label>
                        <input type="email" name="_username" class="form-control form-control-lg" value="{{ last_username }}" required autofocus placeholder="email@example.com">
                    </div>
                    <div class="mb-3 text-start">
                        <label class="form-label"><i class="fas fa-lock me-1"></i> Пароль</label>
                        <input type="password" name="_password" class="form-control form-control-lg" required placeholder="Ваш пароль">
                    </div>
                    <div class="mb-3 text-start">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="_remember_me" id="remember">
                            <label class="form-check-label" for="remember" style="color:var(--gf-muted)">Запам'ятати мене</label>
                        </div>
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <button type="submit" class="btn btn-gf w-100 mb-3">
                        <i class="fas fa-sign-in-alt me-1"></i> Увійти
                    </button>
                </form>

                <div class="my-3">
                    <span style="color:var(--gf-muted)">або увійти через</span>
                </div>

                <div class="d-flex gap-2 justify-content-center mb-3">
                    <a href="{{ path('oauth_google_start') }}" class="btn btn-gf-outline flex-fill">
                        <i class="fab fa-google me-1"></i> Google
                    </a>
                    <a href="{{ path('oauth_discord_start') }}" class="btn btn-gf-outline flex-fill" style="border-color:#5865F2;color:#5865F2;">
                        <i class="fab fa-discord me-1"></i> Discord
                    </a>
                </div>

                <p class="mt-3" style="color:var(--gf-muted)">
                    Немає акаунту? <a href="{{ path('app_register') }}" class="glow-text text-decoration-none">Зареєструватися</a>
                </p>
            </div>
        </div>
    </div>
{% endblock %}
