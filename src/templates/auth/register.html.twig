{% extends 'base.html.twig' %}

{% block title %}Реєстрація{% endblock %}

{% block body %}
    <div class="row justify-content-center mt-5">
        <div class="col-md-5">
            <div class="card-gf text-center">
                <h2 class="glow-text mb-4">Створити акаунт</h2>

                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                {% for field in form %}
                    {% if field.vars.name != '_token' %}
                        <div class="mb-3 text-start">
                            {{ form_label(field) }}
                            {{ form_widget(field, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(field) }}
                        </div>
                    {% endif %}
                {% endfor %}

                <button type="submit" class="btn btn-gf w-100 mb-3">
                    <i class="fas fa-user-plus me-1"></i> Зареєструватися
                </button>
                {{ form_end(form) }}

                <div class="my-3"><span style="color:var(--gf-muted)">або</span></div>

                <div class="d-flex gap-2 justify-content-center mb-3">
                    <a href="{{ path('oauth_google_start') }}" class="btn btn-gf-outline flex-fill">
                        <i class="fab fa-google me-1"></i> Google
                    </a>
                    <a href="{{ path('oauth_discord_start') }}" class="btn btn-gf-outline flex-fill" style="border-color:#5865F2;color:#5865F2;">
                        <i class="fab fa-discord me-1"></i> Discord
                    </a>
                </div>

                <p style="color:var(--gf-muted)">
                    Вже є акаунт? <a href="{{ path('app_login') }}" class="glow-text text-decoration-none">Увійти</a>
                </p>
            </div>
        </div>
    </div>
{% endblock %}
